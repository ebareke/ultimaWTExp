/*
 * ===========================================================================
 * conf/test.config — minimal synthetic dataset for CI / smoke tests.
 *
 *   nextflow run main.nf -profile test,docker          # real, tiny end-to-end
 *   nextflow run main.nf -profile test -stub-run        # topology only, no tools
 *
 * The inputs are produced deterministically by:
 *   python3 examples/scripts/make_synthetic.py
 * which writes a ~12 kb 3-gene "genome", a GTF, six paired-end FASTQs across
 * two conditions, and the matching samplesheet + sample_design.tsv.
 * ===========================================================================
 */

params {
    config_profile_name        = 'Test profile'
    config_profile_description  = 'Synthetic 6-sample RNA-seq dataset for CI'

    // Cap resources so it runs on a small CI runner.
    max_cpus   = 2
    max_memory = 6.GB
    max_time   = 2.h

    input   = "${projectDir}/examples/data/samplesheet.csv"
    design  = "${projectDir}/examples/data/sample_design.tsv"
    fasta   = "${projectDir}/examples/data/genome.fa"
    gtf     = "${projectDir}/examples/data/genes.gtf"

    organism       = 'custom'
    aligner        = 'star'
    pseudo_aligner = 'salmon'
    gene_quant     = 'featurecounts'
    trimmer        = 'fastp'

    // Tiny genome: STAR genomeSAindexNbases is auto-derived from genome length.
    star_two_pass = false
    star_chimeric = false

    run_fusion     = false     // needs a CTAT library
    run_splicing   = true
    run_dge        = true
    run_enrichment = false     // custom organism has no OrgDb
    run_gsea       = false
    skip_fastq_screen = true
    skip_preseq    = true      // preseq is unhappy with ultra-shallow libraries
}

// Re-declare the hard resource limits for this profile (resourceLimits in
// conf/base.config is fixed at parse time from the defaults, before this
// profile lowers max_cpus/max_memory).
process {
    resourceLimits = [ cpus: 2, memory: 6.GB, time: 2.h ]
}
