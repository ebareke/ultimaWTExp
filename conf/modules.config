/*
 * ===========================================================================
 * conf/modules.config — per-process publishDir + default tool arguments.
 *
 * Keeping publishDir and `ext.args` here (rather than hard-coded in each
 * module) means the module files stay generic and reusable, and a site can
 * retune any tool's flags or output layout without editing pipeline logic.
 * ===========================================================================
 */

process {

    publishDir = [
        path:    { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode:    params.publish_dir_mode,
        saveAs:  { fn -> fn.equals('versions.yml') ? null : fn }
    ]

    // ---- Reference -------------------------------------------------------
    withName: 'GUNZIP|GFFREAD|REFERENCE_CHECK|GTF2BED' {
        publishDir = [ path: { "${params.outdir}/reference" }, mode: params.publish_dir_mode,
                       enabled: params.save_reference ]
    }
    withName: 'STAR_GENOMEGENERATE|HISAT2_BUILD|SALMON_INDEX' {
        publishDir = [ path: { "${params.outdir}/reference" }, mode: params.publish_dir_mode,
                       enabled: params.save_reference ]
    }

    // ---- Pre-alignment QC -----------------------------------------------
    withName: 'FASTQC_RAW' {
        ext.prefix = { "${meta.id}_raw" }
        publishDir = [ path: { "${params.outdir}/qc/fastqc/raw" }, mode: params.publish_dir_mode ]
    }
    withName: 'FASTQC_TRIM' {
        ext.prefix = { "${meta.id}_trimmed" }
        publishDir = [ path: { "${params.outdir}/qc/fastqc/trimmed" }, mode: params.publish_dir_mode ]
    }
    withName: 'FASTQ_SCREEN' {
        publishDir = [ path: { "${params.outdir}/qc/fastq_screen" }, mode: params.publish_dir_mode ]
    }

    // ---- Trimming --------------------------------------------------------
    withName: 'FASTP' {
        ext.args = [
            '--cut_front', '--cut_tail',
            '--cut_mean_quality 20',
            '--trim_poly_g', '--trim_poly_x',
            '--length_required 20'
        ].join(' ')
        publishDir = [
            [ path: { "${params.outdir}/trimming/fastp" }, mode: params.publish_dir_mode,
              pattern: '*.{json,html,log}' ],
            [ path: { "${params.outdir}/trimming/fastp" }, mode: params.publish_dir_mode,
              pattern: '*.fastp.fastq.gz', enabled: params.save_trimmed ]
        ]
    }
    withName: 'TRIMGALORE' {
        ext.args = '--quality 20 --length 20'
        publishDir = [ path: { "${params.outdir}/trimming/trimgalore" }, mode: params.publish_dir_mode,
                       pattern: '*.{txt,html,zip}' ]
    }
    withName: 'CUTADAPT' {
        ext.args = '-q 20 --minimum-length 20 -a AGATCGGAAGAGC -A AGATCGGAAGAGC'
        publishDir = [ path: { "${params.outdir}/trimming/cutadapt" }, mode: params.publish_dir_mode,
                       pattern: '*.log' ]
    }

    // ---- Alignment -------------------------------------------------------
    withName: 'STAR_ALIGN' {
        publishDir = [
            [ path: { "${params.outdir}/alignment/star/${meta.id}" }, mode: params.publish_dir_mode,
              pattern: '*.{bam,bai}' ],
            [ path: { "${params.outdir}/alignment/star/${meta.id}/logs" }, mode: params.publish_dir_mode,
              pattern: '*.{out,tab}' ]
        ]
    }
    withName: 'HISAT2_ALIGN' {
        publishDir = [
            [ path: { "${params.outdir}/alignment/hisat2/${meta.id}" }, mode: params.publish_dir_mode,
              pattern: '*.{bam,bai}' ],
            [ path: { "${params.outdir}/alignment/hisat2/${meta.id}/logs" }, mode: params.publish_dir_mode,
              pattern: '*.log' ]
        ]
    }
    withName: 'SAMTOOLS_STATS|SAMTOOLS_FLAGSTAT|SAMTOOLS_IDXSTATS' {
        publishDir = [ path: { "${params.outdir}/qc/samtools/${meta.id}" }, mode: params.publish_dir_mode ]
    }

    // ---- Post-alignment QC ----------------------------------------------
    withName: 'PICARD_MARKDUPLICATES' {
        ext.prefix = { "${meta.id}.markdup" }
        publishDir = [
            [ path: { "${params.outdir}/alignment/markdup/${meta.id}" }, mode: params.publish_dir_mode,
              pattern: '*.bam', enabled: params.save_align_intermeds ],
            [ path: { "${params.outdir}/qc/picard/${meta.id}" }, mode: params.publish_dir_mode,
              pattern: '*.metrics.txt' ]
        ]
    }
    withName: 'PICARD_RNASEQMETRICS' {
        publishDir = [ path: { "${params.outdir}/qc/picard/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'QUALIMAP_RNASEQ' {
        publishDir = [ path: { "${params.outdir}/qc/qualimap/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'RSEQC' {
        publishDir = [ path: { "${params.outdir}/qc/rseqc/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'PRESEQ' {
        ext.args = '-verbose -bam -seed 1'
        publishDir = [ path: { "${params.outdir}/qc/preseq/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'DUPRADAR' {
        publishDir = [ path: { "${params.outdir}/qc/dupradar/${meta.id}" }, mode: params.publish_dir_mode ]
    }

    // ---- Quantification --------------------------------------------------
    withName: 'FEATURECOUNTS' {
        ext.args = { "-g ${params.fc_group_features} -t ${params.fc_count_type}" }
        publishDir = [ path: { "${params.outdir}/quantification/featurecounts" }, mode: params.publish_dir_mode ]
    }
    withName: 'HTSEQ_COUNT' {
        ext.args = '-r pos -f bam --nonunique none'
        publishDir = [ path: { "${params.outdir}/quantification/htseq" }, mode: params.publish_dir_mode ]
    }
    withName: 'SALMON_QUANT' {
        ext.args = '--gcBias --seqBias --validateMappings'
        publishDir = [ path: { "${params.outdir}/quantification/salmon/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'MERGE_COUNTS|TXIMPORT' {
        publishDir = [ path: { "${params.outdir}/quantification/matrices" }, mode: params.publish_dir_mode ]
    }

    // ---- Fusion / splicing ----------------------------------------------
    withName: 'STAR_FUSION' {
        publishDir = [ path: { "${params.outdir}/fusion/${meta.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'RMATS' {
        publishDir = [ path: { "${params.outdir}/splicing/rmats" }, mode: params.publish_dir_mode ]
    }

    // ---- Differential expression + enrichment ---------------------------
    withName: 'DESEQ2' {
        publishDir = [ path: { "${params.outdir}/differential_expression/deseq2/${contrast.id}" },
                       mode: params.publish_dir_mode ]
    }
    withName: 'EDGER' {
        publishDir = [ path: { "${params.outdir}/differential_expression/edger/${contrast.id}" },
                       mode: params.publish_dir_mode ]
    }
    withName: 'CLUSTERPROFILER_ORA' {
        publishDir = [ path: { "${params.outdir}/enrichment/ora/${contrast.id}" }, mode: params.publish_dir_mode ]
    }
    withName: 'CLUSTERPROFILER_GSEA' {
        publishDir = [ path: { "${params.outdir}/enrichment/gsea/${contrast.id}" }, mode: params.publish_dir_mode ]
    }

    // ---- Reporting + provenance -----------------------------------------
    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
        publishDir = [ path: { "${params.outdir}/multiqc" }, mode: params.publish_dir_mode ]
    }
    withName: 'RENDER_REPORT' {
        publishDir = [ path: { "${params.outdir}/reports" }, mode: params.publish_dir_mode ]
    }
    withName: 'DUMP_SOFTWARE_VERSIONS' {
        publishDir = [ path: { "${params.tracedir}" }, mode: params.publish_dir_mode ]
    }
    withName: 'CHECKSUMS' {
        publishDir = [ path: { "${params.outdir}" }, mode: params.publish_dir_mode ]
    }
}
