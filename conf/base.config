/*
 * ===========================================================================
 * conf/base.config — per-process resource requests.
 *
 * Processes are grouped by `label`. Requests escalate with task.attempt on
 * retry, and `resourceLimits` clamps every request to the params.max_*
 * ceilings (the modern replacement for the old check_max() helper), so the
 * same pipeline runs on a laptop (lower the ceilings) and on a fat HPC node
 * (raise them) without edits. Transient failures (137/OOM, 143/walltime) are
 * retried with more resources.
 * ===========================================================================
 */

process {

    // Hard ceilings — no request is scheduled above these.
    resourceLimits = [
        cpus:   params.max_cpus,
        memory: params.max_memory,
        time:   params.max_time
    ]

    cpus   = { 1    * task.attempt }
    memory = { 6.GB * task.attempt }
    time   = { 4.h  * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // ---- Resource classes ------------------------------------------------
    withLabel: process_single {
        cpus   = { 1 }
        memory = { 4.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 2     * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 24.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 12    * task.attempt }
        memory = { 48.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel: process_long {
        time   = { 48.h  * task.attempt }
    }
    withLabel: process_high_memory {
        memory = { 96.GB * task.attempt }
    }

    // ---- Stage-specific overrides ---------------------------------------
    // Genome indexing and STAR alignment are the real resource sinks.
    withLabel: process_index {
        cpus   = { 12 }
        memory = { 64.GB * task.attempt }
        time   = { 12.h  * task.attempt }
    }
    withName: 'STAR_ALIGN|STAR_GENOMEGENERATE|STAR_FUSION' {
        cpus   = { 12 }
        memory = { 64.GB * task.attempt }
    }

    // A failed MultiQC / report should not sink the whole run.
    withName: 'MULTIQC|RENDER_REPORT' {
        errorStrategy = 'ignore'
    }
}
