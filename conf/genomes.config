/*
 * ===========================================================================
 * conf/genomes.config — organism annotation lookup.
 *
 * The pipeline never bundles or downloads reference genomes (see ROADMAP /
 * SECURITY: offline, no redistribution). What it DOES keep here is the small,
 * license-free mapping from an --organism name to the Bioconductor annotation
 * package and KEGG/Reactome organism codes used by the functional-enrichment
 * stage, so DESeq2 results can be mapped to GO/KEGG/Reactome without the user
 * hand-wiring identifiers.
 *
 * `--organism custom` disables organism-aware enrichment ID mapping (ORA still
 * runs if a user supplies their own OrgDb via --gsea_gmt / custom GMTs).
 * ===========================================================================
 */

params {
    organisms {
        'human' {
            orgdb        = 'org.Hs.eg.db'
            kegg_code    = 'hsa'
            reactome_org = 'human'
            msigdb_species = 'Homo sapiens'
            ensembl_dataset = 'hsapiens_gene_ensembl'
        }
        'mouse' {
            orgdb        = 'org.Mm.eg.db'
            kegg_code    = 'mmu'
            reactome_org = 'mouse'
            msigdb_species = 'Mus musculus'
            ensembl_dataset = 'mmusculus_gene_ensembl'
        }
        'rat' {
            orgdb        = 'org.Rn.eg.db'
            kegg_code    = 'rno'
            reactome_org = 'rat'
            msigdb_species = 'Rattus norvegicus'
            ensembl_dataset = 'rnorvegicus_gene_ensembl'
        }
        'custom' {
            orgdb        = null
            kegg_code    = null
            reactome_org = null
            msigdb_species = null
            ensembl_dataset = null
        }
    }
}
