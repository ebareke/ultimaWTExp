/*
 * ===========================================================================
 * conf/test_full.config — full-scale acceptance dataset.
 *
 * Intended for a real human/mouse subset run on an HPC node or cloud. The
 * actual reference + FASTQ URIs are intentionally left null: a site fills them
 * in (or passes a -params-file) because this pipeline never redistributes
 * reference genomes. See docs/INSTALLATION.md for how to stage a CTAT library
 * and reference FASTA/GTF.
 * ===========================================================================
 */

params {
    config_profile_name        = 'Full test profile'
    config_profile_description  = 'Full-size RNA-seq acceptance run (user supplies references)'

    // Example shape — override on the command line / params-file.
    input    = null
    design   = null
    fasta    = null
    gtf      = null
    organism = 'human'

    aligner        = 'star'
    pseudo_aligner = 'salmon'
    gene_quant     = 'featurecounts'
    trimmer        = 'fastp'
    star_two_pass  = true
    star_chimeric  = true

    run_fusion     = true
    run_splicing   = true
    run_dge        = true
    run_enrichment = true
    run_gsea       = true
}
