/*
 * ===========================================================================
 * ultimaWTExp — RNA-seq analysis platform
 * Main Nextflow configuration.
 *
 * FASTQ -> QC -> trim -> align (STAR/HISAT2) -> quantify (featureCounts/HTSeq/
 * STAR/Salmon) -> post-align QC -> fusion (STAR-Fusion) -> splicing (rMATS) ->
 * differential expression (DESeq2/edgeR) -> functional enrichment
 * (clusterProfiler) -> dynamic HTML reports.
 *
 * Values here are global defaults. Per-process resources live in
 * conf/base.config; per-process publishDir + tool flags in conf/modules.config;
 * the bundled synthetic dataset in conf/test.config. CLI flags and -params-file
 * always override these.
 * ===========================================================================
 */

manifest {
    name            = 'ultimaWTExp'
    author          = 'Eric Bareke, Ethan M., Conrad B.'
    homePage        = 'https://ebareke.github.io/ultimaWTExp/'
    description     = 'Production-grade, reproducible RNA-seq workflow — FASTQ to biological interpretation reports'
    mainScript      = 'main.nf'
    defaultBranch   = 'main'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
    doi             = ''
}

params {

    // ---- Input / output --------------------------------------------------
    input              = null          // samplesheet CSV: sample_id,fastq_1,fastq_2,strandedness
    design             = null          // sample_design.tsv (metadata, drives DE)
    outdir             = 'results'
    publish_dir_mode   = 'copy'
    multiqc_title      = null
    email              = null

    // ---- Reference genome ------------------------------------------------
    organism           = 'custom'      // human | mouse | rat | custom (selects annotation DBs)
    genome             = null          // optional named assembly key (see conf/genomes.config)
    fasta              = null          // genome FASTA (.fa / .fa.gz)
    gtf                = null          // gene annotation GTF (.gtf / .gtf.gz)
    gff                = null          // GFF3 alternative; converted to GTF if gtf absent
    transcript_fasta   = null          // optional transcriptome FASTA (else derived from fasta+gtf)
    gene_bed           = null          // 12-column BED for RSeQC (else derived from gtf)
    star_index         = null          // prebuilt STAR index dir (else built)
    hisat2_index       = null          // prebuilt HISAT2 index dir (else built)
    salmon_index       = null          // prebuilt Salmon index dir (else built)
    star_fusion_ref    = null          // CTAT genome library for STAR-Fusion
    save_reference     = true          // publish built indices to outdir/reference

    // ---- Read processing -------------------------------------------------
    trimmer            = 'fastp'       // fastp | trimgalore | cutadapt | none
    skip_trimming      = false
    min_trimmed_reads  = 10000
    clip_r1            = null
    clip_r2            = null
    save_trimmed       = false
    adapter_fasta      = null          // optional explicit adapter FASTA

    // ---- Alignment / quantification --------------------------------------
    aligner            = 'star'        // star | hisat2 | star_hisat2
    star_two_pass      = true          // STAR 2-pass mode
    star_chimeric      = true          // STAR-Fusion-compatible chimeric output
    pseudo_aligner     = 'salmon'      // salmon | null (transcript-level quant)
    gene_quant         = 'featurecounts' // featurecounts | htseq | star (gene-level primary)
    fc_group_features  = 'gene_id'
    fc_count_type      = 'exon'
    fc_extra_attributes = 'gene_name,gene_biotype'
    strandedness       = 'auto'        // auto | unstranded | forward | reverse
    save_align_intermeds = false

    // ---- Optional analysis stages ---------------------------------------
    run_fusion         = true          // STAR-Fusion
    run_splicing       = true          // rMATS
    run_dge            = true          // DESeq2 (+ optional edgeR)
    run_edger          = false         // edgeR alongside DESeq2
    run_enrichment     = true          // clusterProfiler ORA
    run_gsea           = false         // clusterProfiler GSEA (needs gene sets)
    gsea_gmt           = null          // custom GMT for GSEA (overrides MSigDB auto)

    // ---- Differential expression -----------------------------------------
    contrasts          = null          // CSV: id,variable,reference,target (else auto from condition)
    de_fdr             = 0.05
    de_lfc             = 0.0           // |log2FC| threshold for "significant" tagging
    de_min_count       = 10            // pre-filter: genes with sum(counts) >= this
    blocking_factors   = null          // comma-list of design columns to add to the model (e.g. batch,subject_id)

    // ---- Functional enrichment ------------------------------------------
    ora_fdr            = 0.05
    enrichment_dbs     = 'GO,KEGG,Reactome'   // ORA databases
    msigdb_categories  = 'H,C2:CP:KEGG,C5:GO:BP,C5:GO:MF,C5:GO:CC'

    // ---- Splicing (rMATS) ------------------------------------------------
    rmats_read_length  = 100
    rmats_variable_read_length = true
    rmats_novel_ss     = false
    rmats_paired_stats = false

    // ---- QC --------------------------------------------------------------
    skip_fastqc        = false
    skip_fastq_screen  = true          // off by default (needs prebuilt screen DBs)
    fastq_screen_conf  = null
    skip_qualimap      = false
    skip_rseqc         = false
    skip_picard        = false
    skip_preseq        = false
    skip_dupradar      = false
    skip_multiqc       = false

    // ---- Reporting -------------------------------------------------------
    skip_report        = false
    report_formats     = 'html'        // html (Quarto/RMarkdown)

    // ---- Containers ------------------------------------------------------
    // Default to the published Docker Hub image. GHCR mirror also available:
    // ghcr.io/ebareke/ultimawtexp:1.0.0
    container          = 'ebareke/ultimawtexp:1.0.0'

    // ---- Reproducibility / provenance ------------------------------------
    write_checksums    = true          // SHA-256 over published deliverables
    tracedir           = "${params.outdir}/pipeline_info"

    // ---- Resource ceilings (clamped per process in conf/base.config) -----
    max_cpus           = 16
    max_memory         = 128.GB
    max_time           = 72.h

    // ---- Misc ------------------------------------------------------------
    help               = false
    version            = false
    validate_params    = true
    monochrome_logs    = false
}

// ---- Load the named-genome table, then per-process layers ----------------
includeConfig 'conf/genomes.config'
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ---- Container engine + executor profiles --------------------------------
profiles {

    // --- Software provisioning ---
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        apptainer.enabled      = false
        conda.enabled          = false
        process.container      = params.container
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process.container      = params.container
    }
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        process.container      = params.container
    }
    podman {
        podman.enabled         = true
        process.container      = params.container
    }
    conda {
        conda.enabled          = true
        conda.channels         = ['conda-forge', 'bioconda']
        docker.enabled         = false
    }
    wave {
        wave.enabled           = true
        wave.strategy          = 'conda,container'
    }

    // --- HPC schedulers ---
    local      { process.executor = 'local'   }
    slurm      { process.executor = 'slurm';   process.queue = 'general' }
    pbs        { process.executor = 'pbspro';  process.queue = 'workq'   }
    lsf        { process.executor = 'lsf';     process.queue = 'normal'  }
    sge        { process.executor = 'sge';     process.queue = 'all.q'; process.penv = 'smp' }
    awsbatch   { process.executor = 'awsbatch' }          // cloud-ready
    google     { process.executor = 'google-batch' }      // cloud-ready

    // --- Convenience bundles ---
    debug {
        cleanup                = false
        process.beforeScript   = 'echo $HOSTNAME'
        dumpHashes             = true
    }

    // --- Built-in synthetic CI dataset ---
    test       { includeConfig 'conf/test.config'      }
    test_full  { includeConfig 'conf/test_full.config' }
}

// ---- Execution reports (provenance) --------------------------------------
timeline { enabled = true; overwrite = true; file = "${params.tracedir}/execution_timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.tracedir}/execution_report.html" }
trace    { enabled = true; overwrite = true; file = "${params.tracedir}/execution_trace.txt"
           fields  = 'task_id,hash,name,status,exit,realtime,%cpu,peak_rss,peak_vmem' }
dag      { enabled = true; overwrite = true; file = "${params.tracedir}/pipeline_dag.html" }

// Capture the full resolved config of every run for auditability.
process.cache = 'lenient'

manifest.recurseSubmodules = false
